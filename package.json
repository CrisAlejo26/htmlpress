{
  "name": "htmlpress",
  "version": "1.0.0",
  "description": "Bulk convert HTML files to PDF using Puppeteer",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\""
  },
  "keywords": [
    "html",
    "pdf",
    "converter",
    "puppeteer",
    "bulk"
  ],
  "author": "",
  "license": "MIT",
  "type": "module",
  "dependencies": {
    "@types/node": "^25.5.0",
    "puppeteer": "^24.40.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "typescript-eslint": "^8.57.2"
  }
}
